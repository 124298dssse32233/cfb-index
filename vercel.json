{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "output/site",
  "framework": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:slug([a-z0-9][a-z0-9-]+).html",
      "destination": "/teams/:slug.html",
      "permanent": false
    }
  ]
}
