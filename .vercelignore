# Exclude the 3.7GB of individual player pages by default.
# Allow only player pages that are LINKED FROM somewhere else on the site
# (~15k referenced via the audit pass — see _audit_player_refs.py).
# This keeps Mendoza, Iamaleava, every Heisman candidate, every rankings
# row, every storyline mention, etc., reachable without busting Vercel
# Hobby's file-count cap.
output/site/players/*.html
!output/site/players/index.html
!output/site/players/spotlight.html
!output/site/players/the-room.html
!output/site/players/signature-stories.html

