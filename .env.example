DATABASE_URL=sqlite:///./cfb_rankings.db
SPORTSDB_API_KEY=YOUR_SPORTSDB_KEY
SPORTSDB_BASE_URL=https://www.thesportsdb.com
CFBD_API_KEY=YOUR_CFBD_KEY
CFBD_BASE_URL=https://api.collegefootballdata.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
APIFY_API_TOKEN=YOUR_APIFY_TOKEN
YOUTUBE_API_KEY=YOUR_YOUTUBE_KEY
BLUESKY_PUBLIC_API_BASE_URL=https://public.api.bsky.app
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_BASE_URL=https://clob.polymarket.com
REQUEST_TIMEOUT_SECONDS=60
MODEL_VERSION=power-resume-v0.1.0

# ---------------------------------------------------------------------------
# Local LLM routing (optional — zero API cost when set)
# Set LOCAL_LLM_URL to your local llama-server or Ollama OpenAI-compat URL.
# All Anthropic-backed surfaces (sentiment, pulse themes, receipts, chronicle)
# will route here automatically when this is set.
# ---------------------------------------------------------------------------
# LOCAL_LLM_URL=http://localhost:8001/v1    # llama-server (recommended)
# LOCAL_LLM_URL=http://localhost:11434/v1   # Ollama OpenAI-compat layer
# LOCAL_LLM_MODEL=                          # Override model name (optional)
# LOCAL_LLM_TIMEOUT=120                     # HTTP timeout in seconds

# ---------------------------------------------------------------------------
# Chronicle pipeline — local LLM tuning
# ---------------------------------------------------------------------------
# CHRONICLE_PREFER_LLAMASERVER=1            # Prefer llama-server over Ollama
# CHRONICLE_PARALLEL_WORKERS=4             # Parallel page targets (match --parallel N in llama-server)
# CHRONICLE_OLLAMA_WRITER=hf.co/bartowski/Qwen3-14B-GGUF:IQ4_NL  # Upgrade from 8B default
# CHRONICLE_OLLAMA_PLANNER=qwen3:8b        # Planner/critic role

# ---------------------------------------------------------------------------
# Ollama tuning (set before starting Ollama daemon)
# ---------------------------------------------------------------------------
# OLLAMA_FLASH_ATTENTION=1                  # Enable FlashAttention-2 (RTX 5070)
# OLLAMA_KV_CACHE_TYPE=q8_0                # Q8 KV cache — saves VRAM vs fp16
